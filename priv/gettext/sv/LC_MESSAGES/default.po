msgstr "Filtrera på det som faktiskt spelar roll."

#: lib/colt_web/live/home_live.ex:284
#, elixir-autogen, elixir-format
msgid "Filters narrow it down. AI tells you <em>exactly</em> who fits."
msgstr "Filter snävar in det. AI:n säger <em>exakt</em> vilka som passar."

#: lib/colt_web/live/home_live.ex:193
#, elixir-autogen, elixir-format
msgid "Fresh by default."
msgstr "Färska som standard."

#: lib/colt_web/live/home_live.ex:97
#, elixir-autogen, elixir-format

#: lib/colt_web/live/home_live.ex:491
#, elixir-autogen, elixir-format
msgid "Denmark"
msgstr "Danmark"

#: lib/colt_web/live/home_live.ex:212
#, elixir-autogen, elixir-format
msgid "Double-verified contacts."
msgstr "Dubbelverifierade kontakter."

#: lib/colt_web/live/home_live.ex:214
#, elixir-autogen, elixir-format
msgid "Every email and phone we surface actually appears on the company's own site, and we check deliverability separately — so bounces don't trash your domain."
msgstr "Varje e-post och telefonnummer vi tar fram finns faktiskt på företagets egen webbplats, och vi kontrollerar leveransbarheten separat — så att studsar inte skadar din domän."

#: lib/colt_web/live/home_live.ex:86
#, elixir-autogen, elixir-format
msgid "Filter companies based on government data"
msgstr "Filtrera företag utifrån offentliga data"

#: lib/colt_web/live/home_live.ex:203
#, elixir-autogen, elixir-format
msgid "Filter on what actually matters."
msgstr "Filtrera på det som faktiskt spelar roll."

#: lib/colt_web/live/home_live.ex:285
#, elixir-autogen, elixir-format
msgid "Filters narrow it down. AI tells you <em>exactly</em> who fits."
msgstr "Filter snävar in det. AI:n säger <em>exakt</em> vilka som passar."

#: lib/colt_web/live/home_live.ex:194
#, elixir-autogen, elixir-format
msgid "Fresh by default."
msgstr "Färska som standard."

#: lib/colt_web/live/home_live.ex:98
#, elixir-autogen, elixir-format

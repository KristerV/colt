msgstr "Švarūs duomenys"

#: lib/colt_web/live/home_live.ex:181
#, elixir-autogen, elixir-format
msgid "Clean data in. <em>Safe</em> volume out."
msgstr "Švarūs duomenys viduje. <em>Saugus</em> srautas išorėje."

#: lib/colt_web/live/home_live.ex:195
#, elixir-autogen, elixir-format
msgid "Company data straight from the government registries, with contact details scraped recently — not a dump from years ago."
msgstr "Įmonių duomenys tiesiai iš valstybinių registrų, su neseniai surinktais kontaktais — o ne prieš kelis metus išmestas duomenų rinkinys."

#: lib/colt_web/live/home_live.ex:460
#, elixir-autogen, elixir-format

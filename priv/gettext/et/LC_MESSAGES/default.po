msgid "Write"
msgstr "Kirjuta"

#: lib/colt_web/live/home_live.ex:103
#, elixir-autogen, elixir-format
msgid "Write a few emails, AI learns your style"
msgstr "Kirjuta paar kirja, AI õpib sinu stiili"

#: lib/colt_web/live/home_live.ex:380
#, elixir-autogen, elixir-format
msgid "You review every email first. Once you're happy with what the AI does, flip on \"approve automatically\" and it takes over."
msgstr "Sina vaatad iga kirja esmalt üle. Kui oled AI tööga rahul, lülita sisse „kinnita automaatselt\" ja see võtab ohjad üle."

#: lib/colt_web/live/account/billing_live.ex:137
#, elixir-autogen, elixir-format
msgid "Your plan is <em class=\"text-accent\">active</em>."
msgstr "Sinu pakett on <em class=\"text-accent\">aktiivne</em>."

#: lib/colt_web/live/account/billing_live.ex:84

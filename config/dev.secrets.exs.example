import Config

# Copy this file to `dev.secrets.exs` and fill in real keys.
# `dev.secrets.exs` is gitignored. Loaded automatically from `dev.exs`.

config :colt, :openrouter, api_key: "sk-or-v1-REPLACE_ME"

config :colt, :google_cse,
  api_key: "REPLACE_ME",
  engine_id: "REPLACE_ME"

config :colt, discord_webhook_url: "https://discord.com/api/webhooks/REPLACE_ME"

# Get key at: https://myemailverifier.com
config :colt, :myemailverifier, api_key: "REPLACE_ME"

# Nylas v3 (EU region). Hosted-auth-only — we never see the user's OAuth tokens.
# Set redirect_uri to your tunnel URL + "/email-accounts/callback" and add the
# same URL under "Redirect URIs" for the application in the Nylas dashboard.
config :colt, :nylas,
  client_id: "REPLACE_ME",
  api_key: "nyk_v0_REPLACE_ME",
  redirect_uri: "https://YOUR_TUNNEL.example/email-accounts/callback"

# Bolagsverket HVD API (Sweden registry ingest). Free, but per-client OAuth2
# credentials must be requested from
# https://bolagsverket.se/apierochoppnadata/hamtaforetagsinformation/vardefulladatamangder/kundanmalantillapiforvardefulladatamangder.5528.html
# Leave commented out to skip the SE ingest with {:error, :missing_api_key}.
# config :colt, :bolagsverket,
#   client_id: "REPLACE_ME",
#   client_secret: "REPLACE_ME"
